DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
NEXTAUTH_SECRET=any-random-32-char-string
NEXTAUTH_URL=https://your-vercel-url.vercel.app

# Optional — if set, every event synced from the Events tab automatically
# invites this address on Google Calendar
EVENT_ATTENDEE_EMAIL=someone@example.com
